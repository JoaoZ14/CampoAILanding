# Copie para .env e preencha (não commite .env)
GNEWS_API_KEY=

# Opcionais (mesmos nomes do fetch-gnews.mjs)
# GNEWS_MAX_ARTICLES=10
# GNEWS_ARCHIVE_MAX=60
# GNEWS_PAGE_SIZE=10

# Daemon: rodar fetch ao subir? (1 = sim, 0 = só no horário do cron)
# RUN_ON_START=1

# Cron customizado (padrão: todo dia 12:00 no fuso NOTICIAS_TZ)
# NOTICIAS_CRON=0 12 * * *
# NOTICIAS_TZ=America/Sao_Paulo
